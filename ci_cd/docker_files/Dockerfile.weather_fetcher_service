FROM ubuntu:24.04

WORKDIR /app

RUN apt-get update && apt-get install -y \
    libstdc++6 \
    libgrpc++1 \
    libabsl20220623 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY binaries/src/weather_fetcher/weather_fetcher_server /app/weather_fetcher_server

EXPOSE 50051

ENTRYPOINT ["/app/weather_fetcher_server"]