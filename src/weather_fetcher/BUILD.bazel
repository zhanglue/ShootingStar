cc_binary(
    name = "weather_fetcher_server",
    srcs = [
        "main.cpp",
    ],
    deps = [
        ":weather_fetcher_service",
        "@grpc//:grpc++",
        "@grpc//:grpc++_reflection",
        "@abseil-cpp//absl/flags:flag",
